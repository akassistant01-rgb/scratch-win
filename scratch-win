<script>
document.getElementById("codeForm").addEventListener("submit", async function(e){

  e.preventDefault();

  const code = document.getElementById("winningCode").value;

  try {

    const response = await fetch("https://ahmadn8n.duckdns.org/webhook/check-code", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        code: code
      })
    });

    const data = await response.json();

    console.log("Response from n8n:", data);

    // مبدئياً بس لعرض النتيجة
    if(data.status === "valid"){
      alert("🎉 Winner! " + data.prize);
    }
    else if(data.status === "redeemed"){
      alert("⚠️ Code already redeemed");
    }
    else{
      alert("❌ Invalid code");
    }

  } catch (error) {
    console.error(error);
    alert("Error connecting to server");
  }

});
</script>
